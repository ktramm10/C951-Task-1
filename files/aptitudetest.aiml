    <!-- APTITUDE TEST QUESTION 1 LOGIC --> 
<topic name="APTITUDEQ1">
    

    
    <!-- Answer 1 Logic -->
    
    <category>
        <pattern>1</pattern>
        <template>
            
            <!-- some sort of logic to manage scoring -->
            Technology has no shortage of problems to solve. <br/><br/>
        <random>
            <li>A wonderful answer indeed!</li>
            <li>Great choice!</li>
            <li>Duly noted!</li>
        </random>
        <think>
            <set name="topic">APTITUDEQ2</set>
